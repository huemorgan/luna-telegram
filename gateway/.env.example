PORT=10000
DATABASE_URL=postgres://postgres:postgres@localhost:5432/luna_tg

# Required hosted gateway configuration. Never commit real values.
GATEWAY_ADMIN_KEY=replace-with-admin-key
TELEGRAM_TOKEN_ENCRYPTION_KEY=replace-with-64-hex-character-key
PUBLIC_URL=https://luna-tg-gateway.onrender.com

# Optional legacy `default` account compatibility. Set all four or none.
# Hosted accounts are created through POST /accounts instead.
# TELEGRAM_BOT_TOKEN=123456789:replace-with-botfather-token
# TELEGRAM_WEBHOOK_SECRET=replace-with-telegram-webhook-secret
# TG_SHARED_SECRET=replace-with-gateway-plugin-hmac-secret
# LUNA_INBOUND_URL=http://localhost:3000/api/p/plugin-telegram/inbound

# Optional operational tuning.
TG_FORWARD_ATTEMPTS=2
TG_FORWARD_TIMEOUT_MS=120000
TELEGRAM_API_TIMEOUT_MS=30000
# TELEGRAM_API_BASE=https://api.telegram.org
